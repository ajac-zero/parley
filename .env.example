# ---------------------------------------------------------------- required --
# Public origin of this deployment (used for auth callbacks and CORS).
APP_URL=http://localhost:3000

# Secret for session tokens and agent API-key encryption at rest.
# Generate one:  openssl rand -base64 32
# Rotating it invalidates stored agent API keys (they must be re-entered).
APP_SECRET=

# Postgres — all durable state (users, conversations, agents, files).
DATABASE_URL=postgres://parley:parley@localhost:5432/parley

# Redis — live turn streams (resume/replay) and rate limiting.
REDIS_URL=redis://localhost:6379

# S3-compatible object storage for attachment bytes (defaults match the
# bundled MinIO in docker-compose.yml/docker-compose.dev.yml).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=parley
S3_ACCESS_KEY_ID=parley
S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------- optional --
# Region for the S3 endpoint. (default: us-east-1)
#S3_REGION=us-east-1

# Required for MinIO and most non-AWS S3-compatible endpoints. (default: true)
#S3_FORCE_PATH_STYLE=true

# Publicly reachable base URL for the S3 endpoint (real S3/R2/B2, or MinIO
# behind a public reverse proxy). When set, attachments are sent to agents
# for direct image URLs. Non-image attachments are served through Parley's
# short-lived capability endpoint instead.
#S3_PUBLIC_URL=
# Seed the standalone demo agent on first boot. (default: true)
#DEMO_AGENT=true
# Open Responses base URL for the demo agent. (default: http://localhost:8080/v1)
#DEMO_AGENT_URL=http://localhost:8080/v1

# Max attachment upload size, in megabytes. (default: 10)
#FILE_MAX_MB=10

# Chat messages per user per minute; 0 disables rate limiting. (default: 30)
#CHAT_RATE_LIMIT=30

# Abort a turn if the agent sends no events for this long. (default: 120)
#TURN_IDLE_TIMEOUT_SEC=120

# Hard cap on total turn duration. (default: 600)
#TURN_MAX_DURATION_SEC=600

# Lifetime of file_url capabilities handed to agents. Must be at least 60
# seconds longer than TURN_MAX_DURATION_SEC. (default: 900)
#ATTACHMENT_CAPABILITY_TTL_SEC=900

# Refuse agent endpoints that resolve to private/loopback addresses.
# Enable on multi-tenant deployments to prevent SSRF. (default: false)
#BLOCK_PRIVATE_AGENT_ADDRESSES=false

# Let non-admin members register personal agents. (default: true)
#ALLOW_USER_AGENTS=true

# Effect log level: All|Trace|Debug|Info|Warning|Error|Fatal|None (default: Info)
#LOG_LEVEL=Info
